# =============================================================================
# Summer - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored (never commit real keys).
#
# Current requirements:
#   - GCP_PROJECT_ID
#   - GOOGLE_API_KEY (Gemini)
#   - GOOGLE_APPLICATION_CREDENTIALS (your service account json for Firestore)

# -----------------------------------------------------------------------------
# 1. GCP Project ID
# -----------------------------------------------------------------------------
# From the service account JSON you added, the project is:
#   "refine-rack-ecc0e"
#
# Even if you haven't set up hosting yet, use the project where your
# Firestore + vector index lives.
GCP_PROJECT_ID=refine-rack-ecc0e

# -----------------------------------------------------------------------------
# 2. Gemini API Key (already in your .env)
# -----------------------------------------------------------------------------
# The genai client reads GOOGLE_API_KEY automatically.
GOOGLE_API_KEY=your-gemini-api-key-here

# -----------------------------------------------------------------------------
# 3. Service Account for Firestore (you added this file)
# -----------------------------------------------------------------------------
# Set this to the exact filename of the JSON you added.
# The library will use it for Firestore authentication.
GOOGLE_APPLICATION_CREDENTIALS=refine-rack-ecc0e-firebase-adminsdk-fbsvc-8b75b113b1.json

# Note: The filename above matches the file you have in the project root.
# If you rename the json file later, update this value too.

# -----------------------------------------------------------------------------
# Vector Index (your current setup)
# -----------------------------------------------------------------------------
# Collection: knowledge_base
# Field:      embedding
# Index:      looks enabled (CICAgJim14AK)
#
# Our code does:
#   db.collection("knowledge_base").find_nearest(vector_field="embedding", ...)
#
# This should work with the index you described. We will test when you run.

# -----------------------------------------------------------------------------
# Future
# -----------------------------------------------------------------------------
# GROK_API_KEY=...          (when you're ready to switch the main brain)
